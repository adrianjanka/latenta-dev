# Directus (lokal: http://localhost:8055)
DIRECTUS_URL=http://localhost:8055
NUXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Directus Static Token (nach Erstellen in Directus Admin)
DIRECTUS_TOKEN=

# Anthropic API Key (nur serverseitig, nie im Frontend)
ANTHROPIC_API_KEY=
# Optional: Modell für Anreicherung (Default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Unsplash Access Key (Phase 5A – Bild-Seed, nur Scripts)
# https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=abc
